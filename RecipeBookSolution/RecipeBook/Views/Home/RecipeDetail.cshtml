@model RecipeBook.Models.DatabaseModels.Recipe
@using Microsoft.AspNetCore.Hosting
@inject IWebHostEnvironment env
@{
    var ratingAverage = ViewBag.RatingAverage is double avg ? avg : 0;
    var ratingCount = ViewBag.RatingCount is int count ? count : 0;
    var userRating = ViewBag.UserRating is int userRate ? userRate : 0;
}

<div id="recipeRatingToast" class="recipeRatingToast" role="status" aria-live="polite"></div>

<div class="recipeDetailLeft">

    <div class="recipeDetailInfo">
        <h3>@Model.Title</h3>
    </div>

    <div class="recipeDetailImage">
        <div class="recipeDetailImageInner">
            @{

                var imgPhysicalPath = System.IO.Path.Combine(env.WebRootPath ?? string.Empty, "images", "recipes", Model.Id.ToString() + ".jpg");
                var imgExists = System.IO.File.Exists(imgPhysicalPath);
            }
            @if (imgExists)
            {
                <img src="@Url.Content($"~/images/recipes/{Model.Id}.jpg")" alt="Recipe image" />
            }
            else
            {
                <img src="~/img/food-wide.png" />
            }

            <div class="recipeDetailImageStars" role="radiogroup" aria-label="Hodnocení receptu" data-recipe-id="@Model.Id" data-user-rating="@userRating">
                <input type="radio" id="recipeRating5" name="recipeRating" value="5" />
                <label for="recipeRating5" title="5 hvězd"></label>

                <input type="radio" id="recipeRating4" name="recipeRating" value="4" />
                <label for="recipeRating4" title="4 hvězdy"></label>

                <input type="radio" id="recipeRating3" name="recipeRating" value="3" />
                <label for="recipeRating3" title="3 hvězdy"></label>

                <input type="radio" id="recipeRating2" name="recipeRating" value="2" />
                <label for="recipeRating2" title="2 hvězdy"></label>

                <input type="radio" id="recipeRating1" name="recipeRating" value="1" />
                <label for="recipeRating1" title="1 hvězda"></label>
            </div>
        </div>
    </div>

    <div class="recipeDetailDescription">
        <strong>@Html.Raw(@Model.Description?.Replace(Environment.NewLine, "<br/>").Replace("\r\n", "<br/>"))</strong>
    </div>

    <div class="recipeDetailInfo2">
        @{
            var authorName = "Anonymous";
            if (Model.User != null && !string.IsNullOrEmpty(Model.User.Email))
            {
                if (!string.Equals(Model.User.Email, "noname", StringComparison.OrdinalIgnoreCase))
                {
                    authorName = Model.User.Email;
                }
            }
        }
        <p><strong>Autor:</strong> @authorName</p>

        @if (Model.CreatedAt.HasValue)
        {
            <p><strong>Vytvořeno:</strong> @Model.CreatedAt.Value.ToString("dd.MM.yyyy HH:mm")</p>
        }
        @if (Model.Category != null)
        {
            <p><strong>Kategorie:</strong> @Model.Category.Name</p>
        }
        <p><strong>Hodnocení:</strong> <span id="recipeRatingSummary">@ratingAverage.ToString("0.0") (@ratingCount)</span></p>
    </div>


</div>


<div class="recipeDetailPart">
    <h3>Ingredience</h3>
    <strong>@Html.Raw(Model.Ingredients?.Replace(Environment.NewLine, "<br/>").Replace("\r\n", "<br/>"))</strong>
</div>

<div class="recipeDetailPart">
    <h3>Postup</h3>
    <strong>@Html.Raw(Model.Instructions?.Replace(Environment.NewLine, "<br/>").Replace("\r\n", "<br/>"))</strong>
</div>

@section Scripts {
    <script>
        (() => {
            const starsContainer = document.querySelector('.recipeDetailImageStars');
            if (!starsContainer) {
                return;
            }

            const recipeId = Number(starsContainer.dataset.recipeId || 0);
            const initialUserRating = Number(starsContainer.dataset.userRating || 0);
            const summary = document.getElementById('recipeRatingSummary');
            const toast = document.getElementById('recipeRatingToast');
            const inputs = Array.from(starsContainer.querySelectorAll('input[type="radio"]'));
            const labels = Array.from(starsContainer.querySelectorAll('label'));
            let messageTimer = null;

            const showMessage = (text, isError = false) => {
                if (!toast) {
                    return;
                }

                toast.textContent = text;
                toast.classList.add('show');
                toast.classList.toggle('error', isError);

                if (messageTimer) {
                    clearTimeout(messageTimer);
                }

                messageTimer = setTimeout(() => {
                    toast.classList.remove('show');
                    toast.classList.remove('error');
                }, 1800);
            };

            if (initialUserRating >= 1 && initialUserRating <= 5) {
                const initialInput = starsContainer.querySelector(`input[value="${initialUserRating}"]`);
                if (initialInput) {
                    initialInput.checked = true;
                }
            }

            let lastSelectedRating = initialUserRating;

            const clearChecked = () => {
                inputs.forEach(x => x.checked = false);
            };

            const setChecked = (value) => {
                const input = starsContainer.querySelector(`input[value="${value}"]`);
                if (input) {
                    input.checked = true;
                }
            };

            const saveRating = async (selectedStars) => {
                try {
                    const response = await fetch('@Url.Action("RateRecipe", "Home")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            recipeId: recipeId,
                            stars: selectedStars
                        })
                    });

                    const data = await response.json();

                    if (!response.ok || !data.success) {
                        if (response.status === 401) {
                            showMessage('Pro hodnocení se prosím přihlaste.', true);
                        } else {
                            showMessage(data.message || 'Hodnocení se nepodařilo uložit.', true);
                        }

                        if (lastSelectedRating > 0) {
                            setChecked(lastSelectedRating);
                        } else {
                            clearChecked();
                        }
                        return;
                    }

                    lastSelectedRating = selectedStars;
                    if (summary) {
                        summary.textContent = `${Number(data.average).toFixed(1)} (${data.count})`;
                    }
                    showMessage(selectedStars === 0 ? 'Hodnocení odebráno.' : 'Hodnocení uloženo.');
                } catch {
                    showMessage('Došlo k chybě při ukládání hodnocení.', true);
                    if (lastSelectedRating > 0) {
                        setChecked(lastSelectedRating);
                    } else {
                        clearChecked();
                    }
                }
            };

            inputs.forEach(input => {
                input.addEventListener('change', async () => {
                    const selectedStars = Number(input.value);
                    await saveRating(selectedStars);
                });
            });

            labels.forEach(label => {
                label.addEventListener('click', async (e) => {
                    const targetInput = starsContainer.querySelector(`#${label.htmlFor}`);
                    if (!targetInput) {
                        return;
                    }

                    const selectedStars = Number(targetInput.value);
                    if (selectedStars === lastSelectedRating) {
                        e.preventDefault();
                        clearChecked();
                        await saveRating(0);
                    }
                });
            });
        })();
    </script>
}





